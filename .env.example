# JWT signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
# Fernet key for API key encryption — generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-in-production
DATABASE_URL=sqlite:////app/data/autocode.db
UPLOAD_DIR=/app/data/uploads
